targets:
  - name: exampledb
    type: kubernetes
    namespace: default
    pod_selector: "^exampledb"
    db_user: postgres
    secret_ref: exampledb_creds      # key in secrets store
    k8s_secret:                         # optional: pull password from k8s Secret
      name: examplepostgres-secret
      key: superUserPassword

  - name: local-pg
    type: local
    db_user: postgres
    db_name: mydb                       # omit = pg_dumpall
    secret_ref: local_pg_creds

  # ClickHouse backup (remote server via local clickhouse-client)
  - name: ch-trends
    type: clickhouse
    host: "3.2.20.1"
    db_user: example_user
    db_name: example_db
    secret_ref: ch_trends_password

  # ClickHouse backup via Kubernetes pod exec
  - name: ch-analytics
    type: clickhouse
    host: "clickhouse.analytics.svc.cluster.local"
    namespace: analytics
    pod_selector: "^clickhouse"
    db_user: admin
    db_name: analytics_db
    k8s_secret:
      name: clickhouse-credentials
      key: admin-password

destinations:
  - name: remote-1
    type: rsync                         # local | scp | rsync | s3
    host: 3.73.13.3
    user: root
    remote_path: /root/backups/
    auth: key                           # key | password
    ssh_key_path: ~/.ssh/id_rsa
    secret_ref: remote_exia_ssh         # used only if auth=password

  - name: local-archive
    type: local
    path: /mnt/backups/

  # AWS S3 destination
  - name: aws-backups
    type: s3
    bucket: my-backup-bucket
    region: us-east-1
    remote_path: postgres-backups        # prefix for objects in bucket
    use_ssl: true
    access_key_ref: aws_access_key
    secret_key_ref: aws_secret_key

  # Minio destination (self-hosted S3-compatible storage)
  - name: minio-backups
    type: s3
    bucket: backups
    endpoint: minio.example.com:9000    # custom Minio endpoint
    region: us-east-1                    # optional for Minio
    remote_path: postgres-backups
    use_ssl: false                       # set to true if Minio uses HTTPS
    access_key_ref: minio_access_key
    secret_key_ref: minio_secret_key

  # AWS S3 with temporary credentials (session token)
  - name: aws-temp-creds
    type: s3
    bucket: my-backup-bucket
    region: eu-west-1
    remote_path: postgres-backups
    use_ssl: true
    access_key_ref: aws_temp_access_key
    secret_key_ref: aws_temp_secret_key
    session_token_ref: aws_session_token # for temporary credentials

schedules:
  - target: exampledb
    destination: remote-1
    cron: "0 2 * * *"
    compress: gzip
    tmp_dir: /tmp
    retention:
      keep_last: 7

  - target: local-pg
    destination: local-archive
    cron: "0 3 * * *"
    compress: gzip
    tmp_dir: /tmp
    retention:
      keep_last: 14

  # Example: Backup to S3 daily
  - target: exampledb
    destination: aws-backups
    cron: "0 4 * * *"
    compress: gzip
    tmp_dir: /tmp
    retention:
      keep_last: 30

notifications:
  - name: telegram-alerts
    type: telegram
    bot_token_ref: tg_bot_token         # secret ref (backuper secrets set tg_bot_token)
    chat_id: "-100123456789"            # Telegram group/chat ID
    # thread_id: 42                     # optional: forum topic / subgroup thread ID
    on_success: true
    on_failure: true

# Schedule types are automatically derived from the cron expression:
#   Daily:   "X Y * * *"         → daily/
#   Weekly:  "X Y * * 0-6"       → weekly/YYYY-Www/
#   Monthly: "X Y 1 * *"         → monthly/YYYY-MM/
#   Yearly:  "X Y 1 M *"         → yearly/YYYY/
#   Custom:  anything else       → (root directory)
#
# Examples:
#   - target: exampledb
#     destination: local-archive
#     cron: "0 2 * * 1"          # weekly (every Monday at 02:00)
#     compress: gzip
#     retention:
#       keep_last: 4
#
#   - target: exampledb
#     destination: local-archive
#     cron: "0 2 1 * *"          # monthly (1st of each month at 02:00)
#     compress: gzip
#     retention:
#       keep_last: 12
#
#   - target: exampledb
#     destination: local-archive
#     cron: "0 2 1 1 *"          # yearly (January 1st at 02:00)
#     compress: gzip
#     retention:
#       keep_last: 5
